### ============================================================
### 4. ADMIN - CREATE SERVICE
### ============================================================

POST http://localhost:8080/api/admin/services
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "name": "Initial Consultation",
  "description": "First consultation with a specialist",
  "durationMinutes": 30,
  "price": 50.00
}


### ============================================================
### 5. PUBLIC - GET ALL SERVICES
### ============================================================

GET http://localhost:8080/api/services


### ============================================================
### 6. ADMIN - CREATE SPECIALIST
### ============================================================

POST http://localhost:8080/api/admin/specialists
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "fullName": "Dr. John Smith",
  "email": "john.smith@example.com",
  "password": "password123",
  "specialization": "Cardiology",
  "serviceIds": [1]
}


### ============================================================
### 7. PUBLIC - GET ALL SPECIALISTS
### ============================================================

GET http://localhost:8080/api/specialists


### ============================================================
### 8. ADMIN - CREATE AVAILABILITY SLOT
### ============================================================

POST http://localhost:8080/api/admin/availability
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "specialistId": 1,
  "startTime": "2026-06-01T10:00:00",
  "endTime": "2026-06-01T10:30:00"
}


### ============================================================
### 9. ADMIN - CREATE SECOND AVAILABILITY SLOT
### ============================================================

POST http://localhost:8080/api/admin/availability
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "specialistId": 1,
  "startTime": "2026-06-01T10:30:00",
  "endTime": "2026-06-01T11:00:00"
}


### ============================================================
### 10. PUBLIC - GET AVAILABLE SLOTS
### ============================================================

GET http://localhost:8080/api/availability/specialists/1


### ============================================================
### 11. CLIENT - BOOK APPOINTMENT
### ============================================================

POST http://localhost:8080/api/appointments
Content-Type: application/json
Authorization: Bearer {{clientToken}}

{
  "serviceId": 1,
  "specialistId": 1,
  "slotId": 1
}


### ============================================================
### 12. CLIENT - GET MY APPOINTMENTS
### ============================================================

GET http://localhost:8080/api/appointments/my
Authorization: Bearer {{clientToken}}


### ============================================================
### 13. CLIENT - CANCEL APPOINTMENT
### ============================================================

PATCH http://localhost:8080/api/appointments/1/cancel
Authorization: Bearer {{clientToken}}


### ============================================================
### 14. CLIENT - BOOK SAME SLOT AGAIN AFTER CANCELLATION
### ============================================================

POST http://localhost:8080/api/appointments
Content-Type: application/json
Authorization: Bearer {{clientToken}}

{
  "serviceId": 1,
  "specialistId": 1,
  "slotId": 1
}


